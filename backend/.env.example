# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=*

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/detour"

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# NASA APOD (free key at https://api.nasa.gov)
# Defaults to DEMO_KEY which has low rate limits
# ─────────────────────────────────────────────
NASA_API_KEY=DEMO_KEY

# ─────────────────────────────────────────────
# GitHub Personal Access Token
# Settings → Developer settings → Personal access tokens → Classic
# No scopes needed for public repo search
# ─────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here

# ─────────────────────────────────────────────
# Stack Overflow API key (optional — works without it, lower rate limits)
# Get at: https://stackapps.com/apps/oauth/register
# ─────────────────────────────────────────────
SO_API_KEY=your_so_api_key_here

# ─────────────────────────────────────────────
# LeetCode + HN — no keys needed (public APIs)
# ─────────────────────────────────────────────
LEETCODE_GRAPHQL=https://leetcode.com/graphql
HN_ALGOLIA=https://hn.algolia.com/api/v1

# ─────────────────────────────────────────────
# JWST API Key
# ─────────────────────────────────────────────
JWST_API_KEY=your_jwst_api_key_here

# ─────────────────────────────────────────────
# Feed Configuration
# ─────────────────────────────────────────────
# How long to cache each source's response in milliseconds (default: 5 minutes)
FEED_CACHE_TTL_MS=300000
# Default number of cards per page (max: 20)
FEED_PAGE_SIZE_DEFAULT=10
# Set to true to always return mock data (no external API calls)
TEST_MODE=false
